{
  "name": "mosaic",
  "productName": "mosaic",
  "version": "1.0.0",
  "description": "Generate pixel maps for machine learning projects",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "compile-cpp-win": "g++ ./resources/slic.cpp -o ./resources/slic_win.exe",
    "compile-cpp-unix": "g++ ./resources/slic.cpp -o ./resources/slic_unix && chmod +x ./resources/slic_unix",
    "compile-cpp": "npm run compile-cpp-win && npm run compile-cpp-unix",
    "make": "npm run compile-cpp && electron-forge make",
    "make-mac": "npm run compile-cpp && electron-forge make --platform darwin",
    "make-win": "npm run compile-cpp && electron-forge make --platform win32",
    "make-linux": "npm run compile-cpp && electron-forge make --platform linux",
    "package": "npm run compile-cpp && electron-forge package"
  },
  "build": {
    "appId": "com.yourapp.id",
    "asarUnpack": [
      "models/**"
    ],
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "slic_win.exe",
          "slic_unix"
        ]
      }
    ],
    "files": [
      "**/*"
    ],
    "directories": {
      "buildResources": "build"
    }
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true
      }
    }
  },
  "keywords": [],
  "author": "kfilyk <kelvinfilyk@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.21.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^8.1.0",
    "jquery": "^3.7.1",
    "jquery-ui": "^1.14.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^6.0.5",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-rpm": "^6.0.5",
    "@electron-forge/maker-squirrel": "^6.0.5",
    "@electron-forge/maker-zip": "^6.0.5",
    "@electron-forge/plugin-webpack": "^7.5.0",
    "css-loader": "^7.1.2",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "style-loader": "^4.0.0"
  }
}
